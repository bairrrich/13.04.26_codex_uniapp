{
  "name": "superapp-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "npm --prefix apps/next run build",
    "build:turbo": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
